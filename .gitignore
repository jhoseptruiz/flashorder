# ============================
# FlashOrder — Root .gitignore
# ============================

# Dependencias
node_modules/

# Variables de entorno (NUNCA subir al repo)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# Build outputs
dist/
build/

# Antigravity CLI
.antigravitycli/

# Material de referencia local (documentos, PDFs, credenciales)
material/

# Metadata de Windows (Zone.Identifier)
*.Zone.Identifier
