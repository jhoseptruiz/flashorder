# ================================
# FlashOrder Backend — .env.example
# ================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flashorder_db
DB_USER=flashorder_user
DB_PASSWORD=tu_password_seguro

# JWT (para autenticación futura)
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=8h

# Webhooks externos (Uber Eats, etc.)
WEBHOOK_SECRET=secreto_para_validar_webhooks
