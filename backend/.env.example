# ============================================================
# FlashOrder — Backend variables de entorno (EJEMPLO)
# Copia este archivo: cp .env.example .env
# ============================================================

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Base de datos (local sin Docker → apunta a localhost:5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=flashorder_db
DB_USER=postgres
DB_PASSWORD=tu_password_segura

# PostgreSQL Docker (usado por el contenedor de postgres)
POSTGRES_DB=flashorder_db
POSTGRES_PASSWORD=tu_password_segura

# JWT (mínimo 32 caracteres, generá uno con: openssl rand -hex 32)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro_min_32chars
JWT_EXPIRES_IN=15m
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=3d

# CORS
FRONTEND_URL=http://localhost:5173

# Webhook (opcional en desarrollo)
WEBHOOK_SECRET=webhook_secret_opcional
