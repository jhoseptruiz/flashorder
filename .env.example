# ============================================================
# FlashOrder — Variables de entorno
# Copia este archivo: cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ------------------------------------------------------------
DB_NAME=flashorder_db
DB_PASSWORD=tu_password_segura

# Estos valores son fijos para Docker (no cambiar)
# DB_HOST=postgres      → lo define docker-compose
# DB_PORT=5432          → lo define docker-compose
# DB_USER=postgres      → lo define docker-compose

# ------------------------------------------------------------
# AUTENTICACIÓN JWT
# ------------------------------------------------------------
# Usa un string largo y aleatorio (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro_min_32chars

# Duración del access token (formato: 15m, 1h, 24h)
JWT_EXPIRES_IN=15m

# Duración del access token en auth.service.js
ACCESS_TOKEN_EXPIRES=15m

# Duración del refresh token
REFRESH_TOKEN_EXPIRES=3d

# ------------------------------------------------------------
# WEBHOOK (opcional en desarrollo)
# ------------------------------------------------------------
WEBHOOK_SECRET=webhook_secret_opcional
